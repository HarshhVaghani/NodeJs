<%- include('../partials/header', { title: 'Manage Books' }) %>

<div class="flex">
  <%- include('../partials/admin-sidebar', { activePage: 'books' }) %>

  <div class="ml-64 flex-1 min-h-screen bg-gray-100">
    <!-- Top Bar -->
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold text-gray-800">Manage Books</h1>
      <a href="/admin/books/add" class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors flex items-center gap-2">
        <i class="fas fa-plus"></i> Add New Book
      </a>
    </div>

    <div class="p-8">
      <!-- Flash Messages -->
      <% if (success && success.length > 0) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4 flex items-center gap-2">
          <i class="fas fa-check-circle"></i><span><%= success %></span>
        </div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 flex items-center gap-2">
          <i class="fas fa-exclamation-circle"></i><span><%= error %></span>
        </div>
      <% } %>

      <!-- Filters -->
      <div class="bg-white rounded-2xl shadow-sm p-4 mb-6 flex flex-col md:flex-row gap-4">
        <form action="/admin/books" method="GET" class="flex flex-1 gap-3">
          <div class="relative flex-1">
            <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
            <input type="text" name="search" value="<%= search %>" placeholder="Search books..."
              class="w-full pl-9 pr-4 py-2.5 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
          </div>
          <select name="category" class="border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400">
            <option value="all" <%= selectedCategory === 'all' ? 'selected' : '' %>>All Categories</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
          <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition-colors">Filter</button>
          <a href="/admin/books" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2.5 rounded-xl text-sm transition-colors">Clear</a>
        </form>
        <div class="flex items-center text-sm text-gray-500">
          <i class="fas fa-book mr-2"></i><%= books.length %> books
        </div>
      </div>

      <!-- Books Table -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <% if (books.length === 0) { %>
          <div class="text-center py-16">
            <i class="fas fa-book-open text-5xl text-gray-200 mb-4"></i>
            <h3 class="text-lg font-semibold text-gray-500 mb-2">No books found</h3>
            <a href="/admin/books/add" class="bg-amber-500 hover:bg-amber-600 text-white px-6 py-2.5 rounded-xl text-sm font-medium transition-colors inline-block mt-2">
              Add Your First Book
            </a>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Book</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Price</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Stock</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Added</th>
                  <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% books.forEach(book => { %>
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <img
                          src="<%= book.image === 'default-book.jpg' ? '/images/default-book.jpg' : '/uploads/' + book.image %>"
                          alt="<%= book.title %>"
                          class="w-12 h-14 object-cover rounded-lg shadow"
                          onerror="this.src='https://via.placeholder.com/50x65/f3f4f6/9ca3af?text=Book'"
                        />
                        <div>
                          <p class="font-semibold text-gray-800 text-sm max-w-xs truncate"><%= book.title %></p>
                          <p class="text-gray-500 text-xs"><%= book.author %></p>
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <span class="bg-amber-100 text-amber-700 text-xs font-semibold px-2.5 py-1 rounded-full"><%= book.category %></span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="font-bold text-amber-600">₹<%= book.price %></span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-sm <%= book.stock > 0 ? 'text-green-600' : 'text-red-500' %> font-medium">
                        <%= book.stock > 0 ? book.stock + ' in stock' : 'Out of stock' %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-gray-500 text-sm">
                      <%= new Date(book.createdAt).toLocaleDateString('en-IN') %>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center justify-end gap-2">
                        <a href="/book/<%= book._id %>" target="_blank"
                          class="text-gray-400 hover:text-blue-500 transition-colors p-2 hover:bg-blue-50 rounded-lg"
                          title="View">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/admin/books/<%= book._id %>/edit"
                          class="text-gray-400 hover:text-amber-500 transition-colors p-2 hover:bg-amber-50 rounded-lg"
                          title="Edit">
                          <i class="fas fa-edit"></i>
                        </a>
                        <form action="/admin/books/<%= book._id %>?_method=DELETE" method="POST"
                          onsubmit="return confirm('Delete \'<%= book.title %>\'? This cannot be undone.')">
                          <button type="submit"
                            class="text-gray-400 hover:text-red-500 transition-colors p-2 hover:bg-red-50 rounded-lg"
                            title="Delete">
                            <i class="fas fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

</body>
</html>
