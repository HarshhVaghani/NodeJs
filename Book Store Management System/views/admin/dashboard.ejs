<%- include('../partials/header', { title: 'Admin Dashboard' }) %>

<div class="flex">
  <%- include('../partials/admin-sidebar', { activePage: 'dashboard' }) %>

  <!-- Main Content -->
  <div class="ml-64 flex-1 min-h-screen bg-gray-100">
    <!-- Top Bar -->
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
      <div class="text-sm text-gray-500">
        <i class="fas fa-calendar mr-1"></i>
        <%= new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </div>
    </div>

    <div class="p-8">
      <!-- Flash Messages -->
      <% if (success && success.length > 0) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
          <i class="fas fa-check-circle"></i><span><%= success %></span>
        </div>
      <% } %>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl shadow-sm p-6 border-l-4 border-amber-500">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-500 font-medium">Total Books</p>
              <p class="text-4xl font-bold text-gray-800 mt-1"><%= totalBooks %></p>
            </div>
            <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-book text-amber-500 text-2xl"></i>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-l-4 border-blue-500">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-500 font-medium">Categories</p>
              <p class="text-4xl font-bold text-gray-800 mt-1"><%= categoryStats.length %></p>
            </div>
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-tags text-blue-500 text-2xl"></i>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-l-4 border-green-500">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-500 font-medium">Recent Additions</p>
              <p class="text-4xl font-bold text-gray-800 mt-1"><%= recentBooks.length %></p>
            </div>
            <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-plus-circle text-green-500 text-2xl"></i>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Recent Books -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-gray-800">Recently Added Books</h2>
            <a href="/admin/books" class="text-amber-500 hover:text-amber-600 text-sm font-medium">View All</a>
          </div>
          <div class="space-y-3">
            <% if (recentBooks.length === 0) { %>
              <p class="text-gray-400 text-center py-8">No books yet. <a href="/admin/books/add" class="text-amber-500">Add your first book!</a></p>
            <% } %>
            <% recentBooks.forEach(book => { %>
              <div class="flex items-center gap-4 p-3 hover:bg-gray-50 rounded-xl transition-colors">
                <img
                  src="<%= book.image === 'default-book.jpg' ? '/images/default-book.jpg' : '/uploads/' + book.image %>"
                  alt="<%= book.title %>"
                  class="w-12 h-14 object-cover rounded-lg shadow"
                  onerror="this.src='https://via.placeholder.com/60x80/f3f4f6/9ca3af?text=Book'"
                />
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-gray-800 text-sm truncate"><%= book.title %></p>
                  <p class="text-gray-500 text-xs"><%= book.author %></p>
                </div>
                <div class="text-right">
                  <p class="font-bold text-amber-600">₹<%= book.price %></p>
                  <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full"><%= book.category %></span>
                </div>
                <div class="flex gap-2">
                  <a href="/admin/books/<%= book._id %>/edit" class="text-blue-500 hover:text-blue-600 text-sm">
                    <i class="fas fa-edit"></i>
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Category Stats -->
        <div class="bg-white rounded-2xl shadow-sm p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-5">Books by Category</h2>
          <div class="space-y-3">
            <% categoryStats.forEach(stat => { %>
              <% const pct = totalBooks > 0 ? Math.round((stat.count / totalBooks) * 100) : 0 %>
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-gray-600 font-medium"><%= stat._id %></span>
                  <span class="text-gray-500"><%= stat.count %> (<%= pct %>%)</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2">
                  <div class="bg-amber-400 h-2 rounded-full" style="width: <%= pct %>%"></div>
                </div>
              </div>
            <% }) %>
            <% if (categoryStats.length === 0) { %>
              <p class="text-gray-400 text-sm text-center py-4">No data yet</p>
            <% } %>
          </div>
          <div class="mt-6">
            <a href="/admin/books/add" class="w-full bg-amber-500 hover:bg-amber-600 text-white py-3 rounded-xl text-sm font-semibold transition-colors flex items-center justify-center gap-2">
              <i class="fas fa-plus"></i> Add New Book
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
