<%- include('../partials/header', { title: 'Edit Book' }) %>

<div class="flex">
  <%- include('../partials/admin-sidebar', { activePage: 'books' }) %>

  <div class="ml-64 flex-1 min-h-screen bg-gray-100">
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Edit Book</h1>
        <p class="text-gray-500 text-sm truncate max-w-sm"><%= book.title %></p>
      </div>
      <a href="/admin/books" class="text-gray-500 hover:text-gray-700 text-sm transition-colors">
        <i class="fas fa-arrow-left mr-1"></i> Back to Books
      </a>
    </div>

    <div class="p-8">
      <% if (error && error.length > 0) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
          <i class="fas fa-exclamation-circle"></i><span><%= error %></span>
        </div>
      <% } %>

      <form action="/admin/books/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Main Details -->
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-5 pb-3 border-b border-gray-100">Book Information</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Book Title *</label>
                <input type="text" name="title" required value="<%= book.title %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Author *</label>
                <input type="text" name="author" required value="<%= book.author %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Category *</label>
                <select name="category" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm bg-white">
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat %>" <%= book.category === cat ? 'selected' : '' %>><%= cat %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Price (₹) *</label>
                <input type="number" name="price" required min="0" step="0.01" value="<%= book.price %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Stock Quantity</label>
                <input type="number" name="stock" min="0" value="<%= book.stock %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">ISBN</label>
                <input type="text" name="isbn" value="<%= book.isbn || '' %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Publisher</label>
                <input type="text" name="publisher" value="<%= book.publisher || '' %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Published Year</label>
                <input type="number" name="publishedYear" min="1000" max="<%= new Date().getFullYear() %>" value="<%= book.publishedYear || '' %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Rating (0-5)</label>
                <input type="number" name="rating" min="0" max="5" step="0.1" value="<%= book.rating %>"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm"/>
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Description *</label>
                <textarea name="description" required rows="5"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-400 text-sm resize-none"><%= book.description %></textarea>
              </div>
            </div>
          </div>
        </div>

        <!-- Image -->
        <div class="space-y-5">
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-5 pb-3 border-b border-gray-100">Book Cover</h2>

            <!-- Current Image -->
            <div class="mb-4">
              <p class="text-xs text-gray-500 mb-2 font-medium">Current Cover</p>
              <img id="image-preview"
                src="<%= book.image === 'default-book.jpg' ? '/images/default-book.jpg' : '/uploads/' + book.image %>"
                alt="<%= book.title %>"
                class="w-full max-h-48 object-contain rounded-xl bg-gray-50 border border-gray-200 p-2"
                onerror="this.src='https://via.placeholder.com/300x400/f3f4f6/9ca3af?text=No+Image'"
              />
            </div>

            <div class="border-2 border-dashed border-gray-300 rounded-xl p-4 text-center hover:border-amber-400 transition-colors cursor-pointer"
              onclick="document.getElementById('imageInput').click()">
              <i class="fas fa-cloud-upload-alt text-2xl text-gray-300 mb-1"></i>
              <p class="text-xs text-gray-500">Click to change cover image</p>
            </div>
            <input type="file" name="image" id="imageInput" accept="image/*" class="hidden"
              onchange="previewImage(this)" />
            <button type="button" onclick="document.getElementById('imageInput').click()"
              class="w-full mt-3 border border-amber-400 text-amber-600 hover:bg-amber-50 py-2.5 rounded-xl text-sm font-medium transition-colors">
              <i class="fas fa-image mr-1"></i> Change Image
            </button>
          </div>

          <!-- Actions -->
          <div class="bg-white rounded-2xl shadow-sm p-6 space-y-3">
            <button type="submit"
              class="w-full bg-amber-500 hover:bg-amber-600 text-white py-3 rounded-xl font-semibold text-sm transition-colors flex items-center justify-center gap-2">
              <i class="fas fa-save"></i> Save Changes
            </button>
            <a href="/book/<%= book._id %>" target="_blank"
              class="w-full border border-blue-400 text-blue-600 hover:bg-blue-50 py-2.5 rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 block text-center">
              <i class="fas fa-eye"></i> Preview Book
            </a>
            <a href="/admin/books"
              class="w-full border border-gray-300 text-gray-600 hover:bg-gray-50 py-2.5 rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2 block text-center">
              Cancel
            </a>
          </div>

          <!-- Danger Zone -->
          <div class="bg-white rounded-2xl shadow-sm p-6 border border-red-100">
            <h3 class="text-sm font-bold text-red-600 mb-3">Danger Zone</h3>
            <form action="/admin/books/<%= book._id %>?_method=DELETE" method="POST"
              onsubmit="return confirm('Permanently delete \'<%= book.title %>\'? This cannot be undone!')">
              <button type="submit"
                class="w-full bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 py-2.5 rounded-xl text-sm font-semibold transition-colors flex items-center justify-center gap-2">
                <i class="fas fa-trash"></i> Delete This Book
              </button>
            </form>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function previewImage(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = e => {
        document.getElementById('image-preview').src = e.target.result;
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>

</body>
</html>
