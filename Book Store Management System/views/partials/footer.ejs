<footer class="bg-gray-900 text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <i class="fas fa-book-open text-amber-400 text-2xl"></i>
          <span class="text-xl font-bold text-amber-400">BookStore</span>
        </div>
        <p class="text-gray-400 text-sm">Your ultimate destination for books of all genres. Discover, explore, and read.</p>
      </div>
      <div>
        <h3 class="font-semibold text-amber-400 mb-3">Quick Links</h3>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="/" class="hover:text-amber-400 transition-colors">Home</a></li>
          <li><a href="/?category=Fiction" class="hover:text-amber-400 transition-colors">Fiction</a></li>
          <li><a href="/?category=Technology" class="hover:text-amber-400 transition-colors">Technology</a></li>
          <li><a href="/?category=Science" class="hover:text-amber-400 transition-colors">Science</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-amber-400 mb-3">Admin</h3>
        <ul class="space-y-2 text-gray-400 text-sm">
          <% if (currentUser) { %>
            <li><a href="/admin/dashboard" class="hover:text-amber-400 transition-colors">Dashboard</a></li>
            <li><a href="/admin/books" class="hover:text-amber-400 transition-colors">Manage Books</a></li>
            <li><a href="/auth/logout" class="hover:text-amber-400 transition-colors">Logout</a></li>
          <% } else { %>
            <li><a href="/auth/login" class="hover:text-amber-400 transition-colors">Admin Login</a></li>
          <% } %>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-700 mt-8 pt-6 text-center text-gray-500 text-sm">
      <p>&copy; <%= new Date().getFullYear() %> BookStore Management System. All rights reserved.</p>
    </div>
  </div>
</footer>
</body>
</html>
