<%- include('../partials/header', { title: book.title }) %>
<%- include('../partials/navbar') %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/" class="hover:text-amber-600">Home</a>
    <span class="mx-2">/</span>
    <a href="/?category=<%= book.category %>" class="hover:text-amber-600"><%= book.category %></a>
    <span class="mx-2">/</span>
    <span class="text-gray-800"><%= book.title %></span>
  </nav>

  <!-- Book Detail Card -->
  <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
      <!-- Image -->
      <div class="bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center p-8 min-h-96">
        <img
          src="<%= book.image === 'default-book.jpg' ? '/images/default-book.jpg' : '/uploads/' + book.image %>"
          alt="<%= book.title %>"
          class="max-h-96 object-contain rounded-lg shadow-xl"
          onerror="this.src='https://via.placeholder.com/400x550/f3f4f6/9ca3af?text=Book+Cover'"
        />
      </div>

      <!-- Details -->
      <div class="p-8 lg:p-12">
        <div class="flex items-center gap-2 mb-4">
          <span class="bg-amber-100 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full">
            <%= book.category %>
          </span>
          <% if (book.stock > 0) { %>
            <span class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">In Stock</span>
          <% } else { %>
            <span class="bg-red-100 text-red-700 text-xs font-semibold px-3 py-1 rounded-full">Out of Stock</span>
          <% } %>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 mb-3"><%= book.title %></h1>
        <p class="text-lg text-gray-600 mb-4">by <span class="font-semibold text-gray-800"><%= book.author %></span></p>

        <% if (book.rating > 0) { %>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex">
              <% for(let i = 1; i <= 5; i++) { %>
                <i class="fas fa-star text-sm <%= i <= book.rating ? 'text-amber-400' : 'text-gray-300' %>"></i>
              <% } %>
            </div>
            <span class="text-sm text-gray-600"><%= book.rating %>/5</span>
          </div>
        <% } %>

        <div class="text-4xl font-bold text-amber-600 mb-6">₹<%= book.price %></div>

        <p class="text-gray-600 leading-relaxed mb-6"><%= book.description %></p>

        <!-- Book Metadata -->
        <div class="grid grid-cols-2 gap-4 mb-6 bg-gray-50 rounded-xl p-4">
          <% if (book.isbn) { %>
            <div>
              <p class="text-xs text-gray-400 uppercase font-semibold">ISBN</p>
              <p class="text-sm font-medium text-gray-700"><%= book.isbn %></p>
            </div>
          <% } %>
          <% if (book.publisher) { %>
            <div>
              <p class="text-xs text-gray-400 uppercase font-semibold">Publisher</p>
              <p class="text-sm font-medium text-gray-700"><%= book.publisher %></p>
            </div>
          <% } %>
          <% if (book.publishedYear) { %>
            <div>
              <p class="text-xs text-gray-400 uppercase font-semibold">Year</p>
              <p class="text-sm font-medium text-gray-700"><%= book.publishedYear %></p>
            </div>
          <% } %>
          <div>
            <p class="text-xs text-gray-400 uppercase font-semibold">Stock</p>
            <p class="text-sm font-medium text-gray-700"><%= book.stock %> available</p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/" class="flex-1 text-center border-2 border-amber-500 text-amber-600 hover:bg-amber-50 px-6 py-3 rounded-xl font-semibold transition-colors">
            <i class="fas fa-arrow-left mr-2"></i>Back to Books
          </a>
          <% if (currentUser) { %>
            <a href="/admin/books/<%= book._id %>/edit" class="flex-1 text-center bg-amber-500 hover:bg-amber-600 text-white px-6 py-3 rounded-xl font-semibold transition-colors">
              <i class="fas fa-edit mr-2"></i>Edit Book
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Related Books -->
  <% if (related.length > 0) { %>
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">More in <span class="text-amber-600"><%= book.category %></span></h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <% related.forEach(rel => { %>
          <a href="/book/<%= rel._id %>" class="book-card bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl group">
            <div class="h-44 bg-gray-100 overflow-hidden">
              <img
                src="<%= rel.image === 'default-book.jpg' ? '/images/default-book.jpg' : '/uploads/' + rel.image %>"
                alt="<%= rel.title %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                onerror="this.src='https://via.placeholder.com/300x400/f3f4f6/9ca3af?text=No+Image'"
              />
            </div>
            <div class="p-3">
              <h3 class="font-bold text-gray-800 text-sm line-clamp-2 group-hover:text-amber-600 transition-colors"><%= rel.title %></h3>
              <p class="text-gray-500 text-xs mt-1">₹<%= rel.price %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
