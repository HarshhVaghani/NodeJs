<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="text-white min-h-screen">
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/admin/movies" class="text-gray-400 hover:text-yellow-400 transition-colors text-sm">← Back to Movies</a>
    <h1 class="text-3xl font-black mt-2">Add <span class="gradient-text">New Movie</span></h1>
  </div>

  <form action="/admin/movies/add" method="POST" enctype="multipart/form-data" class="glass rounded-2xl p-8">
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Title -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Movie Title *</label>
        <input type="text" name="title" required placeholder="e.g. The Dark Knight"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Director -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Director *</label>
        <input type="text" name="director" required placeholder="e.g. Christopher Nolan"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Release Year -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Release Year *</label>
        <input type="number" name="releaseYear" required min="1888" max="2030" placeholder="e.g. 2008"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Genre -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Genre *</label>
        <select name="genre" required
          class="w-full bg-cinema-800 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
          <option value="">Select Genre</option>
          <% genres.forEach(g => { %>
          <option value="<%= g %>"><%= g %></option>
          <% }) %>
        </select>
      </div>

      <!-- Rating -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Rating (0-10) *</label>
        <input type="number" name="rating" required min="0" max="10" step="0.1" placeholder="e.g. 9.0"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Language -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Language</label>
        <input type="text" name="language" placeholder="e.g. English"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Duration -->
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Duration (minutes)</label>
        <input type="number" name="duration" min="1" placeholder="e.g. 152"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Cast -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Cast</label>
        <input type="text" name="cast" placeholder="e.g. Christian Bale, Heath Ledger, Aaron Eckhart"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <!-- Description -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Description *</label>
        <textarea name="description" required rows="4" placeholder="Write a compelling synopsis..."
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 transition-colors resize-none"></textarea>
      </div>

      <!-- Poster Upload -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Movie Poster</label>
        <div class="border-2 border-dashed border-white/20 rounded-xl p-8 text-center hover:border-yellow-500/50 transition-colors" id="drop-zone">
          <input type="file" name="posterImage" id="posterInput" accept="image/*" class="hidden" onchange="previewImage(this)">
          <div id="preview-container" class="hidden mb-4">
            <img id="preview-img" src="" alt="Preview" class="mx-auto max-h-48 rounded-xl">
          </div>
          <div id="upload-placeholder">
            <div class="text-4xl mb-2">🖼️</div>
            <p class="text-gray-400">Click to upload movie poster</p>
            <p class="text-gray-600 text-sm mt-1">JPG, PNG, WebP up to 5MB</p>
          </div>
          <button type="button" onclick="document.getElementById('posterInput').click()"
            class="mt-4 bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg text-sm transition-colors">
            Choose File
          </button>
        </div>
      </div>
    </div>

    <div class="flex gap-3 mt-8">
      <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-xl transition-colors text-lg">
        🎬 Add Movie
      </button>
      <a href="/admin/movies" class="glass hover:bg-white/10 text-white font-medium px-8 py-3 rounded-xl transition-colors border border-white/20">
        Cancel
      </a>
    </div>
  </form>
</div>

<script>
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
      document.getElementById('preview-img').src = e.target.result;
      document.getElementById('preview-container').classList.remove('hidden');
      document.getElementById('upload-placeholder').classList.add('hidden');
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>

<%- include('../partials/footer') %>
</body>
</html>
