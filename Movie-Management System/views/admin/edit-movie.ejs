<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="text-white min-h-screen">
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/admin/movies" class="text-gray-400 hover:text-yellow-400 transition-colors text-sm">← Back to Movies</a>
    <h1 class="text-3xl font-black mt-2">Edit <span class="gradient-text"><%= movie.title %></span></h1>
  </div>

  <form action="/admin/movies/edit/<%= movie._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="glass rounded-2xl p-8">
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Title -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Movie Title *</label>
        <input type="text" name="title" value="<%= movie.title %>" required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Director *</label>
        <input type="text" name="director" value="<%= movie.director %>" required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Release Year *</label>
        <input type="number" name="releaseYear" value="<%= movie.releaseYear %>" required min="1888" max="2030"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Genre *</label>
        <select name="genre" required class="w-full bg-cinema-800 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
          <% genres.forEach(g => { %>
          <option value="<%= g %>" <%= movie.genre === g ? 'selected' : '' %>><%= g %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Rating (0-10) *</label>
        <input type="number" name="rating" value="<%= movie.rating %>" required min="0" max="10" step="0.1"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Language</label>
        <input type="text" name="language" value="<%= movie.language || 'English' %>"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Duration (minutes)</label>
        <input type="number" name="duration" value="<%= movie.duration || '' %>" min="1"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Cast</label>
        <input type="text" name="cast" value="<%= movie.cast || '' %>"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors">
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Description *</label>
        <textarea name="description" required rows="4"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors resize-none"><%= movie.description %></textarea>
      </div>

      <!-- Poster -->
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-400 mb-2">Update Poster (optional)</label>
        <div class="flex gap-6 items-start">
          <div class="w-32 flex-shrink-0">
            <img src="/uploads/<%= movie.posterImage %>" alt="Current poster" id="current-poster"
              class="w-32 h-44 object-cover rounded-xl border border-white/10"
              onerror="this.src='https://via.placeholder.com/128x176/1a1a2e/fbbf24?text=🎬'">
          </div>
          <div class="flex-1 border-2 border-dashed border-white/20 rounded-xl p-6 text-center hover:border-yellow-500/50 transition-colors">
            <input type="file" name="posterImage" id="posterInput" accept="image/*" class="hidden" onchange="previewImage(this)">
            <p class="text-gray-400 mb-2">Upload new poster to replace current</p>
            <button type="button" onclick="document.getElementById('posterInput').click()"
              class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg text-sm transition-colors">
              Choose New Image
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="flex gap-3 mt-8">
      <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-xl transition-colors text-lg">
        ✅ Save Changes
      </button>
      <a href="/admin/movies" class="glass hover:bg-white/10 text-white font-medium px-8 py-3 rounded-xl transition-colors border border-white/20">Cancel</a>
    </div>
  </form>
</div>

<script>
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
      document.getElementById('current-poster').src = e.target.result;
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>

<%- include('../partials/footer') %>
</body>
</html>
