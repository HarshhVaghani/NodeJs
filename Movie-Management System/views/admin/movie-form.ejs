<%- include('../partials/head') %>

<%- include('../partials/admin-sidebar') %>

<div class="p-8">
  <div class="mb-8">
    <a href="/admin/movies" class="text-cinema-text hover:text-white text-sm flex items-center gap-2 mb-4 w-fit">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Movies
    </a>
    <h1 class="text-3xl font-black text-white"><%= movie ? 'Edit Movie' : 'Add New Movie' %></h1>
    <p class="text-cinema-text mt-1"><%= movie ? 'Update movie information' : 'Fill in the details to add a new movie' %></p>
  </div>

  <%- include('../partials/flash') %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Main Form -->
    <div class="lg:col-span-2">
      <form action="<%= action %>" method="POST" enctype="multipart/form-data" class="space-y-6">

        <div class="bg-cinema-card border border-cinema-border rounded-2xl p-6">
          <h2 class="text-white font-bold mb-5">Basic Information</h2>

          <!-- Title -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-cinema-text mb-2">Movie Title *</label>
            <input type="text" name="title" value="<%= movie ? movie.title : '' %>" required
              class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
              placeholder="Enter movie title"/>
          </div>

          <!-- Director -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-cinema-text mb-2">Director *</label>
            <input type="text" name="director" value="<%= movie ? movie.director : '' %>" required
              class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
              placeholder="Director's name"/>
          </div>

          <!-- Year & Rating Row -->
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-cinema-text mb-2">Release Year *</label>
              <input type="number" name="releaseYear" value="<%= movie ? movie.releaseYear : new Date().getFullYear() %>" required
                min="1888" max="<%= new Date().getFullYear() + 5 %>"
                class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-cinema-text mb-2">Rating (0-10) *</label>
              <input type="number" name="rating" value="<%= movie ? movie.rating : '' %>" required
                min="0" max="10" step="0.1"
                class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
                placeholder="8.5"/>
            </div>
          </div>

          <!-- Duration & Language Row -->
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-cinema-text mb-2">Duration (minutes)</label>
              <input type="number" name="duration" value="<%= movie ? movie.duration : '' %>" min="1"
                class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
                placeholder="120"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-cinema-text mb-2">Language</label>
              <input type="text" name="language" value="<%= movie ? movie.language : 'English' %>"
                class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
                placeholder="English"/>
            </div>
          </div>

          <!-- Genre -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-cinema-text mb-2">Genre * <span class="text-xs">(comma-separated)</span></label>
            <input type="text" name="genre" value="<%= movie ? movie.genre.join(', ') : '' %>" required
              class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
              placeholder="Action, Drama, Thriller"/>
            <div class="flex flex-wrap gap-2 mt-2" id="genre-suggestions">
              <% ['Action','Drama','Comedy','Thriller','Horror','Sci-Fi','Romance','Animation','Documentary','Crime','Fantasy','Adventure'].forEach(g => { %>
                <button type="button" onclick="addGenre('<%= g %>')"
                  class="text-xs bg-cinema-border text-cinema-text hover:bg-cinema-accent hover:text-white px-2 py-1 rounded-full transition-colors">
                  + <%= g %>
                </button>
              <% }) %>
            </div>
          </div>

          <!-- Cast -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-cinema-text mb-2">Cast</label>
            <input type="text" name="cast" value="<%= movie ? movie.cast || '' : '' %>"
              class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors"
              placeholder="Actor 1, Actor 2, Actor 3"/>
          </div>

          <!-- Description -->
          <div>
            <label class="block text-sm font-medium text-cinema-text mb-2">Description *</label>
            <textarea name="description" rows="5" required
              class="w-full bg-cinema-dark border border-cinema-border text-white px-4 py-3 rounded-xl focus:outline-none focus:border-cinema-accent transition-colors resize-none"
              placeholder="Write a compelling movie description..."><%= movie ? movie.description : '' %></textarea>
          </div>
        </div>

        <!-- Poster Upload -->
        <div class="bg-cinema-card border border-cinema-border rounded-2xl p-6">
          <h2 class="text-white font-bold mb-5">Movie Poster</h2>

          <% if (movie && movie.posterImage && movie.posterImage !== 'default-poster.jpg') { %>
          <div class="mb-4">
            <p class="text-cinema-text text-sm mb-2">Current Poster:</p>
            <img src="/uploads/<%= movie.posterImage %>" alt="Current poster" class="w-32 h-44 object-cover rounded-xl border border-cinema-border"/>
          </div>
          <% } %>

          <div class="border-2 border-dashed border-cinema-border rounded-xl p-8 text-center hover:border-cinema-accent transition-colors" id="drop-zone">
            <svg class="w-12 h-12 text-cinema-text mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-cinema-text mb-1">Click to upload or drag & drop</p>
            <p class="text-cinema-text text-xs">PNG, JPG, WEBP up to 5MB</p>
            <input type="file" name="posterImage" accept="image/*" class="hidden" id="poster-input" onchange="previewImage(this)"/>
            <button type="button" onclick="document.getElementById('poster-input').click()"
              class="mt-3 bg-cinema-border hover:bg-cinema-accent text-cinema-text hover:text-white px-4 py-2 rounded-lg text-sm transition-colors">
              Choose File
            </button>
          </div>
          <div id="preview-container" class="mt-4 hidden">
            <img id="preview-img" class="w-32 h-44 object-cover rounded-xl border border-cinema-accent"/>
            <p id="preview-name" class="text-cinema-text text-xs mt-1"></p>
          </div>
        </div>

        <!-- Submit -->
        <div class="flex gap-4">
          <button type="submit"
            class="flex-1 bg-cinema-accent hover:bg-red-700 text-white py-3.5 rounded-xl font-semibold transition-colors text-lg">
            <%= movie ? '💾 Update Movie' : '🎬 Add Movie' %>
          </button>
          <a href="/admin/movies" class="px-6 py-3.5 border border-cinema-border text-cinema-text hover:text-white hover:border-white rounded-xl transition-colors flex items-center">
            Cancel
          </a>
        </div>
      </form>
    </div>

    <!-- Tips Sidebar -->
    <div class="space-y-5">
      <div class="bg-cinema-card border border-cinema-border rounded-2xl p-5">
        <h3 class="text-white font-bold mb-3">💡 Tips</h3>
        <ul class="space-y-2 text-cinema-text text-sm">
          <li class="flex gap-2"><span class="text-cinema-accent">•</span> Use the official movie title</li>
          <li class="flex gap-2"><span class="text-cinema-accent">•</span> Rating should be out of 10</li>
          <li class="flex gap-2"><span class="text-cinema-accent">•</span> Separate multiple genres with commas</li>
          <li class="flex gap-2"><span class="text-cinema-accent">•</span> Use a high-quality poster image</li>
          <li class="flex gap-2"><span class="text-cinema-accent">•</span> Write a spoiler-free description</li>
        </ul>
      </div>

      <div class="bg-cinema-card border border-cinema-border rounded-2xl p-5">
        <h3 class="text-white font-bold mb-3">🎬 Genre Presets</h3>
        <div class="grid grid-cols-2 gap-2">
          <% [['Action, Thriller', '💥'], ['Comedy, Romance', '😄'], ['Horror, Thriller', '👻'], ['Sci-Fi, Adventure', '🚀'], ['Drama, Crime', '🎭'], ['Animation, Family', '🎨']].forEach(([g, e]) => { %>
            <button type="button" onclick="setGenre('<%= g %>')"
              class="text-xs bg-cinema-dark hover:bg-cinema-border text-cinema-text hover:text-white p-2 rounded-lg transition-colors text-left">
              <%= e %> <%= g %>
            </button>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

</main>
</div>

<script>
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('preview-img').src = e.target.result;
      document.getElementById('preview-name').textContent = input.files[0].name;
      document.getElementById('preview-container').classList.remove('hidden');
    };
    reader.readAsDataURL(input.files[0]);
  }
}

function addGenre(genre) {
  const input = document.querySelector('input[name="genre"]');
  const current = input.value.trim();
  const genres = current ? current.split(',').map(g => g.trim()) : [];
  if (!genres.includes(genre)) {
    genres.push(genre);
    input.value = genres.join(', ');
  }
}

function setGenre(genre) {
  document.querySelector('input[name="genre"]').value = genre;
}

// Drag and drop
const dropZone = document.getElementById('drop-zone');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-cinema-accent'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-cinema-accent'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('border-cinema-accent');
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) {
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById('poster-input').files = dt.files;
    previewImage(document.getElementById('poster-input'));
  }
});
</script>

</body></html>
